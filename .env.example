# WeChat AI Writer v1.2.0 - 完整配置示例

# ============================================
# LLM Configuration - 智谱 GLM-5（推荐）
# ============================================
LLM_PROVIDER=glm
ZAI_API_KEY=your_glm5_api_key_here
ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 备选：OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-xxx

# 备选：豆包
# LLM_PROVIDER=doubao
# DOUBAO_API_KEY=xxx
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ============================================
# Search Configuration - SerpAPI
# ============================================
SEARCH_PROVIDER=serpapi
SERPAPI_KEY=your_serpapi_key_here

# ============================================
# WeChat Configuration - 自动管理 Token（推荐）
# ============================================
# 方式1: 自动获取（推荐，无需手动更新）
WECHAT_APPID=wxXXXXXXXXXXXXXXXXXXXXXXXX
WECHAT_APPSECRET=your_appsecret_here

# 方式2: 静态 Token（备选，需定期更新）
# WECHAT_ACCESS_TOKEN=72_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ============================================
# 配置说明
# ============================================
#
# 1. 智谱 GLM-5（推荐）
#    - 访问: https://open.bigmodel.cn/
#    - 注册并获取 API Key
#    - 新用户免费额度
#    - 中文优化，价格实惠（¥0.005/千tokens）
#
# 2. SerpAPI
#    - 访问: https://serpapi.com/
#    - 注册并获取 API Key
#    - 免费 100次/月
#
# 3. 微信配置（推荐自动模式）
#    - 登录微信公众平台
#    - 获取 AppID 和 AppSecret
#    - 系统自动获取和管理 Token
#    - 无需手动更新，无需配置 IP 白名单
#
# 4. 静态 Token（备选）
#    - 获取方式: curl "https://api.weixin.qq.com/cgi-bin/token?grant_type=client_credential&appid=你的AppID&secret=你的AppSecret"
#    - 有效期: 2小时
#    - 需要定期手动更新
