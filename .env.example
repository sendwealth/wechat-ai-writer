# LLM Configuration - 智谱 GLM-5（推荐）
# ============================================
LLM_PROVIDER=glm
ZAI_API_KEY=your_glm5_api_key_here
ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 备选：OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-xxx

# 备选：豆包
# LLM_PROVIDER=doubao
# DOUBAO_API_KEY=xxx
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ============================================
# Search Configuration - SerpAPI
# ============================================
SEARCH_PROVIDER=serpapi
SERPAPI_KEY=your_serpapi_key_here

# ============================================
# Image Generation Configuration - 图片生成
# ============================================
# 可选值: placeholder (免费), cogview (推荐), dalle3
IMAGE_PROVIDER=placeholder

# CogView 配置（推荐，便宜）
# 使用 ZAI_API_KEY（与 GLM-5 共用）
# 价格: ¥0.06/张 (标准), ¥0.03/张 (批量)

# DALL-E 3 配置（高质量，贵）
# 使用 OPENAI_API_KEY
# 价格: $0.04/张 (标准), $0.08/张 (HD)
# IMAGE_PROVIDER=dalle3

# ============================================
# WeChat Configuration - 自动管理 Token
# ============================================
# 方式1: 自动获取（推荐）
WECHAT_APPID=wxXXXXXXXXXXXXXXXXXXXXXXXX
WECHAT_APPSECRET=your_appsecret_here

# 方式2: 静态 Token（备选）
# WECHAT_ACCESS_TOKEN=72_xxxxxxxxxxxxxxxxxxxxx

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ============================================
# 配置说明
# ============================================
#
# 1. 智谱 GLM-5（推荐）
#    - 访问: https://open.bigmodel.cn/
#    - 注册并获取 API Key
#    - 新用户免费额度
#    - 中文优化，价格实惠（¥0.005/千tokens）
#    - 同时支持 CogView 图片生成
#
# 2. SerpAPI
#    - 访问: https://serpapi.com/
#    - 注册并获取 API Key
#    - 免费 100次/月
#
# 3. 图片生成
#    - CogView（推荐）: ¥0.06/张，使用 ZAI_API_KEY
#    - DALL-E 3: $0.04/张，使用 OPENAI_API_KEY
#    - placeholder: 免费，测试用
#
# 4. 微信配置
#    - 登录微信公众平台
#    - 获取 AppID 和 AppSecret
#    - 系统自动获取和管理 Token
